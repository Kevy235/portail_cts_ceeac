# ─── Base de données PostgreSQL ─────────────────────────────────────────────
# Obligatoire en production.
DATABASE_URL=postgresql://utilisateur:motdepasse@hote:5432/portail_cts

# ─── Sécurité ───────────────────────────────────────────────────────────────
# Obligatoire en production. Générer avec : openssl rand -base64 48
JWT_SECRET=

# ─── Compte administrateur initial (créé au premier démarrage) ─────────────
# ADMIN_PASSWORD est obligatoire en production.
ADMIN_EMAIL=admin@ceeac-eccas.org
ADMIN_PASSWORD=
ADMIN_NAME=Secrétariat CTS-DSS

# ─── Serveur ────────────────────────────────────────────────────────────────
PORT=3001
# URL publique de la plateforme (utilisée dans les liens des e-mails).
APP_URL=https://documents.votre-domaine.org
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=50

# ─── Diffusion des rapports par e-mail (optionnel) ──────────────────────────
# Si SMTP_HOST est vide, la fonction « Diffuser par e-mail » est désactivée.
SMTP_HOST=
SMTP_PORT=587
# true pour TLS implicite (port 465), false pour STARTTLS (port 587).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Plateforme CTS-DSS <no-reply@ceeac-eccas.org>"


